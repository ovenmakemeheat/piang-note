---
const links = [
	{ label: "Notes", to: "/" },
	{ label: "Categories", to: "/categories/" },
	{ label: "Graph", to: "/graph/" },
];
---

<header
	class="mx-auto flex max-w-[1180px] items-center justify-between border-rule border-b px-6 py-[18px] max-[820px]:items-start max-[820px]:flex-col max-[820px]:gap-3"
>
	<a class="text-base no-underline" href="/">piang note</a>
	<div class="flex flex-wrap items-center justify-end gap-2">
		<nav aria-label="Primary navigation" class="flex flex-wrap justify-end gap-2">
			{
				links.map((link) => (
					<a
						href={link.to}
						class="border border-transparent px-[9px] py-1.5 no-underline hover:border-rule hover:bg-paper"
					>
						{link.label}
					</a>
				))
			}
		</nav>
		<button
			type="button"
			class="grid size-9 place-items-center border border-rule bg-paper text-ink hover:bg-soft"
			data-theme-toggle
			aria-label="Switch theme"
		>
			<svg
				data-theme-icon="sun"
				xmlns="http://www.w3.org/2000/svg"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path>
				<path d="M12 20v2"></path>
				<path d="m4.93 4.93 1.41 1.41"></path>
				<path d="m17.66 17.66 1.41 1.41"></path>
				<path d="M2 12h2"></path>
				<path d="M20 12h2"></path>
				<path d="m6.34 17.66-1.41 1.41"></path>
				<path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
			<svg
				data-theme-icon="moon"
				xmlns="http://www.w3.org/2000/svg"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
				class="hidden"
			>
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
			</svg>
		</button>
	</div>
</header>

<script>
	const toggle = document.querySelector("[data-theme-toggle]");
	const sunIcon = document.querySelector('[data-theme-icon="sun"]');
	const moonIcon = document.querySelector('[data-theme-icon="moon"]');

	function syncThemeButton() {
		const theme = document.documentElement.dataset.theme || "dark";
		if (toggle) {
			toggle.setAttribute(
				"aria-label",
				theme === "dark" ? "Switch to light theme" : "Switch to dark theme",
			);
		}
		sunIcon?.classList.toggle("hidden", theme !== "dark");
		moonIcon?.classList.toggle("hidden", theme === "dark");
	}

	syncThemeButton();

	toggle?.addEventListener("click", () => {
		const nextTheme =
			document.documentElement.dataset.theme === "dark" ? "light" : "dark";
		document.documentElement.dataset.theme = nextTheme;
		localStorage.setItem("theme", nextTheme);
		syncThemeButton();
	});
</script>
